{
  "info": {
    "name": "活动策划公司管理系统 - 全面参数化测试",
    "description": "使用数据驱动的参数化接口测试集合，覆盖 80+ 个接口测试用例",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/EventPlanning_Management",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "用户管理接口测试",
      "item": [
        {
          "name": "{{case_id}} - {{case_name}}",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"状态码为 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"验证返回 flag\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.flag).to.eql(pm.variables.get(\"expected_flag\"));",
                  "});",
                  "",
                  "pm.test(\"验证返回 data 内容\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var expectedData = pm.variables.get(\"expected_data_contains\");",
                  "    if (expectedData && expectedData.trim() !== \"\") {",
                  "        var dataStr = JSON.stringify(jsonData.data);",
                  "        pm.expect(dataStr).to.include(expectedData);",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"记录测试结果\", function () {",
                  "    var caseId = pm.variables.get(\"case_id\");",
                  "    var caseName = pm.variables.get(\"case_name\");",
                  "    var flag = pm.variables.get(\"expected_flag\");",
                  "    var actualFlag = pm.response.json().flag;",
                  "    ",
                  "    if (flag === actualFlag) {",
                  "        console.log('✅ ' + caseId + ' - ' + caseName + ': 通过');",
                  "    } else {",
                  "        console.log('❌ ' + caseId + ' - ' + caseName + ': 失败');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text",
                  "disabled": "{{#unless username}}true{{/unless}}"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text",
                  "disabled": "{{#unless password}}true{{/unless}}"
                },
                {
                  "key": "roleId",
                  "value": "{{roleId}}",
                  "type": "text",
                  "disabled": "{{#unless roleId}}true{{/unless}}"
                },
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "type": "text",
                  "disabled": "{{#unless userId}}true{{/unless}}"
                },
                {
                  "key": "name",
                  "value": "{{name}}",
                  "type": "text",
                  "disabled": "{{#unless name}}true{{/unless}}"
                },
                {
                  "key": "sex",
                  "value": "{{sex}}",
                  "type": "text",
                  "disabled": "{{#unless sex}}true{{/unless}}"
                },
                {
                  "key": "phone",
                  "value": "{{phone}}",
                  "type": "text",
                  "disabled": "{{#unless phone}}true{{/unless}}"
                },
