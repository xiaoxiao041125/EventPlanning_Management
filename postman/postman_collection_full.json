                  "    if (flag === actualFlag) {",
                  "        console.log('✅ ' + caseId + ' - ' + caseName + ': 通过');",
                  "    } else {",
                  "        console.log('❌ ' + caseId + ' - ' + caseName + ': 失败');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "type": "text",
                  "disabled": "{{#unless userId}}true{{/unless}}"
                },
                {
                  "key": "reimbursementType",
                  "value": "{{reimbursementType}}",
                  "type": "text",
                  "disabled": "{{#unless reimbursementType}}true{{/unless}}"
                },
                {
                  "key": "amount",
                  "value": "{{amount}}",
                  "type": "text",
                  "disabled": "{{#unless amount}}true{{/unless}}"
                },
                {
                  "key": "expenseDate",
                  "value": "{{expenseDate}}",
                  "type": "text",
                  "disabled": "{{#unless expenseDate}}true{{/unless}}"
                },
                {
                  "key": "description",
                  "value": "{{description}}",
                  "type": "text",
                  "disabled": "{{#unless description}}true{{/unless}}"
                },
                {
                  "key": "status",
                  "value": "{{status}}",
                  "type": "text",
                  "disabled": "{{#unless status}}true{{/unless}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/{{endpoint}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{endpoint}}"]
            }
          }
        }
      ]
    }
  ]
}
